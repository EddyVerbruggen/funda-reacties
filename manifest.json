{
  "manifest_version": 3,
  "name": "Funda Reacties",
  "version": "1.5.3",
  "description": "Reageer op woningen op Funda.nl — deel ervaringen over bezichtigingen, buurten en vraagprijzen met andere huizenzoekers.",
  "incognito": "split",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://www.funda.nl/*",
    "https://*.supabase.co/*",
    "https://api.pdok.nl/*",
    "https://api.kadaster.nl/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.funda.nl/detail/*",
        "https://www.funda.nl/koop/*",
        "https://www.funda.nl/huur/*"
      ],
      "css": ["styles/panel.css"],
      "js": [
        "lib/supabase.min.js",
        "supabase-client.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16_grey.png",
      "48": "icons/icon48_grey.png",
      "128": "icons/icon128_grey.png"
    }
  }
}
