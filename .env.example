# Supabase Configuration
# ============================================================================
# Kopieer dit bestand naar supabase-client.js en vul de juiste waarden in.
# 
# Haal deze credentials op via:
# 1. Log in op https://supabase.com
# 2. Open je project
# 3. Ga naar Settings > API
# 4. Kopieer de Project URL en anon/public key
# ============================================================================

# Je Supabase project URL (bijv. https://abcdefgh.supabase.co)
SUPABASE_URL=YOUR_SUPABASE_URL

# Je Supabase anon/public key (lange string die begint met eyJ...)
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ============================================================================
# ⚠️ BELANGRIJK
# ============================================================================
# - Gebruik ALLEEN de "anon/public" key, NOOIT de "service_role" key!
# - De anon key is veilig om te delen, deze is read-only door RLS policies
# - De service_role key geeft volledige database toegang en mag NOOIT in
#   frontend code staan!
# ============================================================================
